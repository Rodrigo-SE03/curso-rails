<p style="color: green"><%= notice %></p>

<% content_for :title, "Coins" %>

<h1>Moedas</h1>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Descrição</th>
      <th>Sigla</th>
      <th>Imagem</th>
      <th>Ações</th>
    </tr>
  </thead>

  <tbody>
    <% @coins.each do |coin| %>
      <tr>
        <td><%= coin.id %></td>
        <td><%= coin.description %></td>
        <td><%= coin.acronym %></td>
        <td><%= image_tag coin.url_image, width: 40 %></td>
        <td>
          <%= link_to "Editar", edit_coin_path(coin) %>
          <%= link_to "Ver", coin %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to "Nova Moeda", new_coin_path %>